---
import { render } from "astro:content";
import { differenceInDays, format, formatDistance } from "date-fns";
import Layout from "@layouts/Layout.astro";
import Navbar from "@components/Navbar.astro";
import { getAllShorts } from "@scripts/content";

const visibleShorts = await getAllShorts();

const shorts = await Promise.all(
  visibleShorts.map(async (short, i, arr) => {
    return {
      post: await render(short),
      short,
      prev: i > 0 ? arr[i - 1] : undefined,
    };
  }),
);
---

<Layout
  title="Shorts"
  description="Notas curtas, updates e pequenos fragmentos que nao viram artigo completo."
  themeColor="#101a2b"
  class="overflow-x-hidden"
  style="--un-skew: 5deg; --un-rotate: 9deg; --un-scale: 1.2"
>
  <Navbar />

  <main class="flex justify-center w-full mt-xl lg:mt-[3%] homepage mx-6">
    {
      shorts.length === 0 && (
        <div class="flex flex-col gap-2">
          <h1>Ainda nao tem shorts publicados.</h1>
          <a href="/" class="color-highlight font-500">
            Voltar para a home
          </a>
        </div>
      )
    }
    <div>
      <header class="article-grid w-full mx-auto px-8 mb-24">
        <h1 class="font-600 text-4xl lg:text-5xl xl:text-7xl mb-6 ps-0 md:ps-8">
          Shorts
        </h1>
        <p class="text-xl ps-0 md:ps-8 leading-relaxed">
          Aqui ficam pensamentos pequenos, updates e notas que nao precisam
          virar um artigo completo.
        </p>
      </header>
      <ul class="flex flex-col list-none m-0 p-0">
        {
          shorts.map(({ post, short, prev }) => (
            <li class="shorts-section flex flex-col mx-auto prose max-w-full prose-code:before:content-none prose-code:after:content-none text-base w-full">
              <header class="w-full px-8 article-grid">
                <li class="shorts-timeline ps-0 md:ps-8 !max-md:list-none">
                  <div class="shorts-outline border-body-600 max-md:hidden" />
                  <div class="text-sm md:text-base color-text-600 font-mono">
                    <time datetime={short.data.date.toISOString()}>
                      {format(short.data.date, "LLL d, yyyy")}
                    </time>
                    {
                      prev &&
                        differenceInDays(prev.data.date, short.data.date) > 0 && (
                          <span class="text-sm md:text-base color-text-300">
                            ({formatDistance(prev.data.date, short.data.date)}{" "}
                            antes)
                          </span>
                        )
                    }
                  </div>

                  <h2 class="shorts-title font-500 lg:text-4xl mt-8 mb-6 lg:mb-8">
                    {short.data.title}
                  </h2>
                </li>
              </header>

              <main class="main-article article-grid px-8 pt-2 lg:px-0 text-base lg:text-xl leading-10 color-text-700 leading-loose w-full">
                <div class="shorts-timeline ps-0 md:ps-8 pb-20">
                  <div class="shorts-outline border-body-600 max-md:hidden" />
                  <post.Content />
                </div>
              </main>
            </li>
          ))
        }
      </ul>
    </div>
  </main>
</Layout>

<style>
  .shorts-title {
    font-family: var(--font-family-article-title);
  }
  .shorts-outline {
    z-index: -1;
    position: absolute;
    left: 0;
    border-width: 1px;
    border-style: dashed;
    margin-left: -20.5px;
    margin-top: 10px;
    width: 0px;
    height: 100%;
  }
  .shorts-outline.first {
    border-style: dashed;
  }
  .shorts-timeline {
    z-index: 1;
    position: relative;
    list-style-type: disc;
  }
  .shorts-timeline::marker {
    color: var(--body-200);
    font-size: 1.5rem;
  }

  .main-article .shorts-timeline :global(p) {
    margin-top: 0;
    margin-bottom: 0;
  }

  .main-article .shorts-timeline :global(p + p) {
    margin-top: 1.35em;
  }

  .main-article .shorts-timeline :global(.shorts-mixtape) {
    margin-top: 2.4em;
    padding-top: 1.1em;
    display: grid;
    gap: 0.9em;
    border-top: 1px solid rgb(148 163 184 / 0.14);
  }

  .main-article .shorts-timeline :global(.shorts-mixtape-label) {
    margin: 0;
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-300);
  }

  .main-article .shorts-timeline :global(.shorts-track) {
    display: grid;
    gap: 0.2em;
    padding: 0.9rem 1rem 1rem;
    border: 1px solid rgb(148 163 184 / 0.14);
    border-radius: 14px;
    background: rgb(255 255 255 / 0.02);
    text-decoration: none;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background-color 180ms ease;
  }

  .main-article .shorts-timeline :global(.shorts-track:hover) {
    transform: translateY(-2px);
    border-color: rgb(148 163 184 / 0.28);
    background: rgb(255 255 255 / 0.04);
  }

  .main-article .shorts-timeline :global(.shorts-track-kicker) {
    margin-top: 0.1rem;
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-300);
  }

  .main-article .shorts-timeline :global(.shorts-track-thumb) {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: 10px;
    border: 1px solid rgb(148 163 184 / 0.12);
    background: rgb(255 255 255 / 0.03);
    margin: 0 0 0.35rem;
  }

  .main-article .shorts-timeline :global(.shorts-track strong) {
    font-size: 1rem;
    line-height: 1.45;
    color: var(--text-800);
    font-weight: 600;
  }
</style>
