---
import { getRecentTracks } from "../scripts/lastfm";

const tracks = await getRecentTracks(5); // Pega as últimas 5
---

<div class="flex flex-col gap-4 mt-8">
  <div class="flex items-center gap-2 text-sm font-bold color-text-500 uppercase tracking-widest">
    Recent Tracks <span class="text-lg">🎧</span>
  </div>

  <div class="flex flex-col gap-6">
    {tracks.map((track: any) => (
      <a
        href={track.url}
        target="_blank"
        rel="noreferrer noopener"
        class="flex items-center gap-4 group cursor-pointer no-underline"
      >
        <div class="relative flex-shrink-0">
          <img
            src={track.image[2]['#text'] || '/placeholder-album.png'}
            alt={track.name}
            class="w-12 h-12 rounded-md object-cover outline outline-1 outline-body-700 group-hover:scale-105 transition-transform duration-300"
          />
        </div>

        <div class="flex flex-col overflow-hidden">
          <span class="text-sm font-bold color-text-800 group-hover:color-brand-500 transition-colors truncate">
            {track.name}
          </span>
          <span class="text-xs color-text-400 truncate">
            {track.artist['#text']}
          </span>
        </div>
      </a>
    ))}
  </div>
</div>
