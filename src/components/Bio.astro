---
import { Image } from "astro:assets";
import ExternalLink from "./ExternalLink.astro";
import Email from "./icons/Email.astro";
import Github from "./icons/Github.astro";
import Twitter from "./icons/Twitter.astro";
import avatarMj from "@assets/avatars/itsmisa.png";
import { getAllShorts } from "@scripts/content";
import { format } from "date-fns";
import { enUS, ptBR } from "date-fns/locale";
import { homeCopy, type Language } from "../i18n";

interface Props {
  language?: Language;
}

const { language = "pt" } = Astro.props;
const copy = homeCopy[language];
const latestShort = (await getAllShorts(language))[0];
const dateLocale = language === "pt" ? ptBR : enUS;
const dateFormat = language === "pt" ? "d LLL yyyy" : "LLL do yyyy";
const socialEmail = "misaelucas@gmail.com";
const socialEmailCodePoints = socialEmail
  .split("")
  .map((char) => char.charCodeAt(0));
---

<div class="flex flex-col md:flex-row justify-between w-full min-w-0 gap-8">
  <div class="bio-copy flex flex-col gap-6 flex-grow-0 w-full min-w-0 max-w-[44rem] text-xl leading-8">
    <h1 class="text-5xl sm:text-6xl lg:text-7xl font-900 mb-2">
      {copy.bio.heading}
    </h1>

    <div class="color-text-400 flex flex-col gap-4 w-full min-w-0 max-w-[38rem]">
      <p class="text-base uppercase tracking-[0.18em] color-text-500">
        {copy.bio.role}
      </p>

      <p>{copy.bio.intro}</p>

      {copy.bio.work.map((paragraph) => <p>{paragraph}</p>)}

      <p class="bio-interests text-sm color-text-300 tracking-wide font-bold">
        {copy.bio.interests}
      </p>

      <p class="text-base color-text-300">{copy.bio.location} 🌵</p>
    </div>
    <div class="flex flex-col gap-2">
      <div class="flex gap-4 text-3xl color-text-700">
        <ExternalLink
          noIcon
          href="https://github.com/misaelucas"
          target="_blank"
          aria-label="GitHub"
          class="inline-flex transition-transform duration-200 hover:scale-110 hover:color-text-900"
        >
          <Github />
        </ExternalLink>
        <ExternalLink
          noIcon
          href="https://x.com/misaelucas22"
          target="_blank"
          aria-label="Twitter"
          class="inline-flex transition-transform duration-200 hover:scale-110 hover:color-text-900"
        >
          <Twitter />
        </ExternalLink>
        <ExternalLink
          noIcon
          href=""
          aria-label="Email"
          class="email-target inline-flex transition-transform duration-200 hover:scale-110 hover:color-text-900 relative"
        >
          <div
            class="obfuscated-email hidden"
            data-email={JSON.stringify(socialEmailCodePoints)}
          />
          <Email />
        </ExternalLink>
      </div>
    </div>
    {
      latestShort && (
        <div class="flex flex-col gap-2 items-center mt-6 group self-start max-md:w-full">
          <div class="md:hidden self-start flex flex-col gap-1 w-full text-base">
            <span class="color-text-500">{copy.latestShort}</span>
            <time class="color-text-300" datetime={latestShort.data.date.toISOString()}>
              {format(latestShort.data.date, dateFormat, { locale: dateLocale })}
            </time>
          </div>
          <a
            class="inline-flex flex-col max-md:w-full md:flex-row transition-all gap-3 md:items-center outline outline-1 outline-body-500 group-hover:outline-body-300 md:rounded-[20px] ps-[10px] pe-[20px] py-1 text-base"
            href={copy.shortsHref}
          >
            <h3 class="text-sm transition-all bg-body-600 group-hover:bg-body-300 rounded-[10px] px-3 text-nowrap max-md:hidden">
              Shorts
            </h3>
            {latestShort.data.title}
          </a>
        </div>
      )
    }
  </div>

  <div
    class="relative w-full lg:max-w-[390px] max-w-[300px] aspect-ratio-1 flex-shrink-0 group relative h-min [container-type:inline-size]"
  >
    <span
      class="rounded-md image-container -z-1 outline outline-1 outline-body-800"
    ></span>
    <Image
      id="custom-avatar"
      alt="Profile picture"
      quality={100}
      class="rounded-md z-2 outline outline-1 outline-body-500 h-full bg-body-900 transition-transform duration-300 group-hover:scale-[1.01]"
      src={avatarMj}
      width={400}
      height={400}
      sizes=""
    />
  </div>
</div>

<noscript>
  <style>
    .email-target {
      display: none;
    }
  </style>
</noscript>

<script>
  const email = document.querySelector(".obfuscated-email");
  const emailTarget = document.querySelector(".email-target");

  if (email instanceof HTMLElement && emailTarget instanceof HTMLElement) {
    const myEmail = JSON.parse(email.dataset.email ?? "[]");
    emailTarget.setAttribute(
      "href",
      `mailto:${String.fromCharCode(...myEmail)}`,
    );
  }

  const avatar = document.querySelector("#custom-avatar");
  if (avatar instanceof HTMLImageElement) {
    avatar.addEventListener("load", () => {
      avatar.classList.add("fade-in");
    });

    if (avatar.complete) {
      avatar.classList.add("fade-in");
    }
  }
</script>

<style>
  .bio-copy {
    max-width: min(44rem, calc(100vw - 4rem));
  }

  .bio-interests {
    word-break: normal;
    overflow-wrap: break-word;
  }
</style>
